PORT=8787
MAX_BODY_BYTES=6291456
CORS_ORIGIN=http://127.0.0.1:5173

# LLM deep formula analysis (OpenAI Responses API by default)
# Use either LLM_API_KEY or OPENAI_API_KEY. Keys are read only by the backend.
# LLM_API_KEY=
# OPENAI_API_KEY=
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-5.6-luna
# LLM_API_STYLE=responses
# LLM_TIMEOUT_MS=90000
# LLM_MAX_OUTPUT_TOKENS=8000
# LLM_STRICT_JSON=true

# For OpenAI-compatible providers that only expose Chat Completions:
# LLM_API_STYLE=chat_completions
# LLM_BASE_URL=https://your-provider.example/v1
# LLM_MODEL=your-model-name

# OCR provider configuration:
# MATHPIX_APP_ID=
# MATHPIX_APP_KEY=
# OCR_SERVICE_URL=http://127.0.0.1:8501/predict
